{
  "lexicon": 1,
  "id": "social.atshare.preference",
  "defs": {
    "main": {
      "type": "record",
      "key": "literal:self",
      "description": "User's preferred share destinations across the open social web. Stored on the user's PDS so their preference travels with them to any site running atShare.",
      "record": {
        "type": "object",
        "required": ["primaryNetwork"],
        "properties": {
          "primaryNetwork": {
            "type": "string",
            "description": "Primary share destination identifier",
            "knownValues": ["bluesky", "mastodon"]
          },
          "networks": {
            "type": "array",
            "description": "Configured network destinations",
            "items": {
              "type": "ref",
              "ref": "#networkConfig"
            }
          }
        }
      }
    },
    "networkConfig": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "knownValues": ["atproto", "activitypub"]
        },
        "appView": {
          "type": "string",
          "format": "uri",
          "description": "For ATProto: the AppView/client URL (e.g. https://bsky.app)"
        },
        "instance": {
          "type": "string",
          "format": "uri",
          "description": "For ActivityPub: the instance URL (e.g. https://mastodon.social)"
        }
      }
    }
  }
}
