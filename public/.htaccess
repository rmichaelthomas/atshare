# Short-URL alias for the component bundle.
# Keeps the two-line install snippet short and guards against any older
# docs/snippets that referenced /selector.js before the /dist/ path was
# documented. 301 so browsers cache the redirect.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^selector\.js$ /dist/atshare-selector.js [R=301,L]
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
  # JS component bundles — versioned path, safe for long-term caching + CORS
  <FilesMatch "\.(js|cjs)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>

  # Static assets (images, icons) — 1 week cache
  <FilesMatch "\.(png|svg|ico)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  # HTML pages — always revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
